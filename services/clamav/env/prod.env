# ═══════════════════════════════════════════════════════════════
# ClamAV — PROD Environment Variables
# ═══════════════════════════════════════════════════════════════
APP_ENV=prod

CLAMAV_NO_FRESHCLAM_CHECK=false
FRESHCLAM_CHECKS=24
TZ=Asia/Kolkata

# Health check tuning
HEALTHCHECK_INTERVAL=60s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=3
HEALTHCHECK_START=5m
